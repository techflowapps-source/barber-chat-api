# Variáveis de produção para o backend NestJS (Render/Railway/Fly)
# JWT_* devem ser IGUAIS aos da Vercel para o login do painel funcionar na API.

NODE_ENV=production
PORT=3000

# Supabase Postgres — conexão direta (funciona no Render)
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.kgeoxyqfvopjilgmiolb.supabase.co:5432/postgres?schema=public&sslmode=require

# Upstash Redis — https://console.upstash.com (grátis)
# REDIS_URL=rediss://default:SEU_TOKEN@SEU_HOST.upstash.io:6379

JWT_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=https://barber-chat-api-main.vercel.app,http://localhost:5173

WA_SESSION_NAME=barbershop-main
WA_SESSION_DIR=/app/sessions

ADMIN_EMAIL=barbershoppaiva@gmail.com
ADMIN_PASSWORD=change-me-in-production

APPOINTMENT_REMINDER_MINUTES=15
PROMOTION_SEND_INTERVAL_MS=3000
