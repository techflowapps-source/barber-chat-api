NODE_ENV=production
PORT=3000

# Supabase PostgreSQL (Dashboard > Settings > Database > Connection string > URI)
# Substitua [YOUR_DB_PASSWORD] pela senha do banco definida ao criar o projeto
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.kgeoxyqfvopjilgmiolb.supabase.co:5432/postgres?schema=public

# Supabase API (opcional — integrações futuras)
SUPABASE_URL=https://kgeoxyqfvopjilgmiolb.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis — use Upstash em produção (https://upstash.com) ou Redis local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — gere strings aleatórias longas em produção
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — inclua a URL do frontend na Vercel
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# WhatsApp session
WA_SESSION_NAME=barbershop-main
WA_SESSION_DIR=./sessions

# Admin
ADMIN_EMAIL=barbershoppaiva@gmail.com
ADMIN_PASSWORD=change-me-in-production

# Agendamentos
APPOINTMENT_REMINDER_MINUTES=15
PROMOTION_SEND_INTERVAL_MS=3000
